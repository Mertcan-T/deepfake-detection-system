# === Deepfake Projesi Özel Eklemeleri ===

# 1. Veri Setleri
# Binlerce video içeren veri setleri GitHub limitlerini aşar
/data/
/datasets/
/raw_data/

# 2. Model Ağırlıkları
# Eğitilen modellerin (.h5, .pth, .weights) boyutları çok büyüktür
*.h5
*.pth
*.weights
*.pkl
*.onnx

# 3. Videolar ve Çıktılar
# src/videolar altındaki ham videoları dışlıyoruz
src/videolar/*.mp4
src/videolar/*.avi
src/videolar/*.mov

# Örnek senaryonun işlenmiş halini GitHub'da göstermek istersen
# bu satırın başına '#' koyarak istisna tutabilirsin:
# !src/videolar/Deepfake_Example_islenmis_mtcnn.mp4

# 4. Geçici Dosyalar ve Loglar
/frames/
/output/
/temp/
*.log